# Public site base URL (trailing slash optional)
SITE_BASE_URL=https://scrapauctionindia.com/auctions

# Google Analytics 4 — set in GitHub Actions secrets for production builds
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Paywall / billing placeholders (disabled until live billing sub-round)
# Do not put API secrets here — server/CI only
NEXT_PUBLIC_BILLING_CHECKOUT_ENABLED=false
NEXT_PUBLIC_BILLING_PROVIDER=
NEXT_PUBLIC_PAYWALL_DEMO_MODE=false
# BILLING_WEBHOOK_SECRET=

# Optional webhook for refresh failure notifications
NOTIFY_WEBHOOK_URL=
